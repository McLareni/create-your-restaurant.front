export type SubMenuItem = {
  id: string;
  href: string;
  label: string;
  moduleKey?: string;
};

export type MenuItem = {
  id: string;
  href?: string;
  icon: React.ElementType;
  label: string;
  moduleKey?: string;
  highlight?: boolean;
